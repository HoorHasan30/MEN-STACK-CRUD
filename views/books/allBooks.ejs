<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Books</title>
</head>
<body>
    <%- include('../partials/navbar.ejs') %>

    <h1>All Books</h1>

    <% allBooks.forEach( (book) => { %>
        <a href="/all-books/<%= book._id %>"><%= book.title %></a>    
    <% }) %>
</body>
</html>